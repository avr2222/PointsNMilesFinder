# Set these as GitHub Actions Secrets (Settings → Secrets → Actions)
# Never commit actual values — this file documents what secrets are needed

# Required for email alerts
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# Optional — only needed if you upgrade to a premium exchange rate API
# The default uses frankfurter.app which is free and needs no key
EXCHANGE_RATE_API_KEY=optional_key_here
